{
  "name": "demonictutor-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build:wasm": "PATH=\"$HOME/Library/Caches/.wasm-pack/.wasm-bindgen-cargo-install-0.2.115/bin:$PATH\" wasm-pack build ../.. --target web --out-dir apps/web/src/wasm/pkg --out-name demonictutor_ui",
    "predev": "npm run build:wasm",
    "dev": "vite",
    "deps:check": "node ./scripts/check-direct-deps.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc -b --pretty false",
    "prebuild": "npm run build:wasm",
    "build": "npm run typecheck && vite build",
    "check": "npm run format:check && npm run lint && npm run build",
    "audit": "npm audit --audit-level=moderate",
    "preview": "vite preview"
  },
  "dependencies": {
    "solid-js": "1.9.12"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-solid": "0.14.5",
    "globals": "17.4.0",
    "prettier": "3.8.1",
    "typescript": "6.0.2",
    "typescript-eslint": "8.57.2",
    "vite": "8.0.3",
    "vite-plugin-solid": "2.11.11"
  },
  "packageManager": "npm@10.9.4"
}
