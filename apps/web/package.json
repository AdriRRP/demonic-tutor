{
  "name": "demonictutor-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build:wasm": "PATH=\"$HOME/Library/Caches/.wasm-pack/.wasm-bindgen-cargo-install-0.2.115/bin:$PATH\" wasm-pack build ../.. --target web --out-dir apps/web/src/wasm/pkg --out-name demonictutor_ui",
    "predev": "npm run build:wasm",
    "dev": "vite",
    "prebuild": "npm run build:wasm",
    "build": "tsc -b && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "solid-js": "1.9.9"
  },
  "devDependencies": {
    "typescript": "5.9.3",
    "vite": "7.1.7",
    "vite-plugin-solid": "2.11.8"
  }
}
